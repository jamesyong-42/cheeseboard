{
  "productName": "Cheeseboard",
  "version": "0.1.3",
  "identifier": "com.cheeseboard.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "onboarding",
        "title": "Cheeseboard",
        "width": 480,
        "height": 520,
        "resizable": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "shortDescription": "Cross-device clipboard sync over Tailscale",
    "longDescription": "Cheeseboard syncs your clipboard across all devices on your Tailscale network. Copy on one device, paste on another.",
    "copyright": "Copyright (c) 2026 James Yong",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jamesyong-42/cheeseboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxQkI1RDA0NjZFNTkwREEKUldUYWtPVm1CRjI3d2JRV0FyWFFFSW90TkpYZGNjcytDTkhaSVdYMVJlaUZpSUtyQmhnOHpOWHAK"
    }
  }
}
